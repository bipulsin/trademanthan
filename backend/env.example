# Place this file at the repository root as `.env` (e.g. /home/ubuntu/trademanthan/.env).
# The backend loads it via `backend/env_bootstrap.py` with override=True so values apply even if systemd has empty placeholders.

# Local Development Configuration
DATABASE_URL=sqlite:///./trademanthan.db
SECRET_KEY=your-secret-key-here-change-in-production
GOOGLE_CLIENT_ID=428560418671-t59riis4gqkhavnevt9ve6km54ltsba7.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://www.tradewithcto.com/login.html
REDIS_URL=redis://localhost:6379
DOMAIN=www.tradewithcto.com
ENVIRONMENT=development
DEBUG=true
# JWT lifetime (minutes). Default ~365d — survives page refresh; logout clears storage on client.
ACCESS_TOKEN_EXPIRE_MINUTES=525600

# Production Configuration (EC2 Server)
# DATABASE_URL=postgresql://trademanthan:trademanthan123@localhost/trademanthan
# DOMAIN=www.tradewithcto.com
# GOOGLE_REDIRECT_URI=https://www.tradewithcto.com/login.html

# Telegram: POST /auth/notify-trade-channel (intraoption / pivot-breakout Notify button)
# Bot must be admin on the channel. Do not commit real tokens.
# TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_TRADEWITHCTO_CHAT_ID=@TradeWithCTO
# Used by POST /auth/notify-trade-channel and POST /auth/notify-telegram-user-message

# ---------------------------------------------------------------------------
# Email (daily health report + ChartInk ranking CSV attachment)
# Loaded from repo root `.env` by backend/env_bootstrap.py — must be uncommented on EC2.
# Verify after edit: PYTHONPATH=. python3 backend/scripts/verify_email_env.py
# Then: sudo systemctl restart trademanthan-backend
# ---------------------------------------------------------------------------
# ALERT_EMAIL=you@example.com
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_login
# SMTP_PASSWORD=your_smtp_app_password
# SMTP_FROM_EMAIL=support@tradewithcto.com
# Optional: ranking CSV recipient. If unset, same as ALERT_EMAIL; else legacy default tradentical@gmail.com
# CHARTINK_RANKING_EMAIL=you@example.com

# Daily Futures 15m strip: Nifty momentum threshold in percent for close-vs-close classification.
# 0.01 means 0.01%.
# DAILY_FUTURES_NIFTY_MOMENTUM_THRESHOLD_PCT=0.01
# DAILY_FUTURES_NIFTY_MOMENTUM_MODE=atr
# DAILY_FUTURES_NIFTY_MOMENTUM_ATR_MULTIPLIER=0.25

# ChartInk → Daily Futures webhooks (secret query param must match)
# CHARTINK_DF_SECRET=tradewithctodailyfuture
# CHARTINK_DF_BEARISH_SECRET=tradewithctodailyfuture_bearish
# Optional: clear persisted raw webhook JSON in inbox/ every N days (scheduler runs 08:45 IST daily)
# CHARTINK_DF_INBOX_REFRESH_ENABLED=1
# CHARTINK_DF_INBOX_REFRESH_DAYS=5
