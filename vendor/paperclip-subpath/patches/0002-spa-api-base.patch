diff --git a/ui/src/lib/api-base.ts b/ui/src/lib/api-base.ts
new file mode 100644
index 0000000..06059e8
--- /dev/null
+++ b/ui/src/lib/api-base.ts
@@ -0,0 +1,10 @@
+/**
+ * REST API root for same-origin Paperclip backend, respecting Vite `base` / `BASE_URL`.
+ * Root hosting: `/api`. Subpath hosting (e.g. `/paperclip/`): `/paperclip/api`.
+ */
+export function getApiRoot(): string {
+  const raw = import.meta.env.BASE_URL ?? "/";
+  const trimmedBase = raw.replace(/\/+$/, "") || "/";
+  if (trimmedBase === "/") return "/api";
+  return `${trimmedBase}/api`;
+}
